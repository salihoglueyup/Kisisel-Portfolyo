# Server Environment Variables
NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://localhost:27017/mern_portfolyo
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_here_change_in_production
CLIENT_URL=http://localhost:5173

# İlk superadmin hesabı (sadece `node seedAdmin.js` için kullanılır)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change_this_strong_password
SEED_ADMIN_NAME=YBS Admin

# E-posta (SMTP) — opsiyonel. Tanımlı değilse e-posta gönderimi no-op olur.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="YBS Portfolyo <no-reply@example.com>"
# Yeni iletişim mesajlarının ve şifre sıfırlama isteklerinin gideceği adres
ADMIN_EMAIL=admin@example.com
